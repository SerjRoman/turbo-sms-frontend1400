{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "jsx": "react-native",
        "moduleResolution": "node",
        "strict": true,
        "paths": {
            "@shared/*": ["./src/shared/*"],
            "@modules/*": ["./src/modules/*"],
            "@assets/*": ["./src/assets/*"]
        }
    },
    "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
